{
  "framework": null,
  "buildCommand": "vite build",
  "installCommand": "npm install",
  "outputDirectory": "dist/client",
  "functions": {
    "dist/server/server.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/server/server.js"
    }
  ]
}