{
  "framework": null,
  "buildCommand": "vite build",
  "outputDirectory": "dist/client",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/dist/server/server.js" }
  ],
  "functions": {
    "dist/server/server.js": {
      "runtime": "nodejs20.x"
    }
  }
}